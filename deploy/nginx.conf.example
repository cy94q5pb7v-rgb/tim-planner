# Пример reverse-proxy nginx для ТИМ Планера (TLS терминируется на nginx).
# Приложение слушает 127.0.0.1:8000, наружу — 443 с сертификатом.

server {
    listen 80;
    server_name planner.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name planner.example.com;

    ssl_certificate     /etc/letsencrypt/live/planner.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/planner.example.com/privkey.pem;

    # вложения задач — до 15 МБ (base64 ~ +33%)
    client_max_body_size 25m;

    location / {
        proxy_pass         http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 180s;   # @agent может думать до ~170с
    }
}
