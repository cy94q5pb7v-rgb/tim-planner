# ТИМ Планер — пример конфигурации.
# Скопируйте в .env  (`cp .env.example .env`)  и заполните значения.
# ВСЕ настройки опциональны, КРОМЕ PLANNER_SECRET в проде.

# ─────────────────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО В ПРОДЕ: секрет для подписи сессий (>= 32 случайных символов)
# Сгенерировать:  python -c "import secrets; print(secrets.token_urlsafe(48))"
PLANNER_SECRET=change-me-to-a-long-random-string-min-32-chars

# ─────────────────────────────────────────────────────────────
# Пути (по умолчанию всё в ./data). Обычно менять не нужно.
# PLANNER_DATA_DIR=./data
# PLANNER_DB_PATH=./data/planner.db
# PLANNER_FILES_DIR=./data/planner_files
# PLANNER_USERS_FILE=./data/users.json
# PLANNER_FRONTEND_DIR=./frontend

# Имя cookie сессии и срок жизни токена (дней)
# PLANNER_COOKIE=planner_session
# PLANNER_TOKEN_TTL_DAYS=7

# ─────────────────────────────────────────────────────────────
# ИИ-агент чата (@agent) — ОПЦИОНАЛЬНО. Без настройки @agent отвечает,
# что не настроен. Вариант A — любой OpenAI-совместимый API:
# PLANNER_AGENT_API_URL=https://api.openai.com/v1/chat/completions
# PLANNER_AGENT_API_KEY=sk-...
# PLANNER_AGENT_MODEL=gpt-4o-mini
# Вариант B — внешняя CLI-команда (промпт на stdin, ответ на stdout):
# PLANNER_AGENT_CMD=my-agent-cli --json

# ─────────────────────────────────────────────────────────────
# GitHub-синхронизация — ОПЦИОНАЛЬНО. Импорт issues в доску, авто-создание
# issue при переводе задачи на этап «Разработка», закрытие issue → «Пром».
# GITHUB_REPO=owner/repo
# PLANNER_GITHUB_TOKEN=ghp_xxx           # токен с доступом к issues репозитория
# GITHUB_SYNC_ENABLED=1                  # фоновый авто-импорт (1/0)
# GITHUB_SYNC_HOURS=3                    # период авто-импорта, часов

# ─────────────────────────────────────────────────────────────
# Почтовые уведомления о смене статуса/этапа задач — ОПЦИОНАЛЬНО, по умолчанию OFF.
# PLANNER_NOTIFY_ENABLED=1
# PLANNER_NOTIFY_TO=team@example.com
# PLANNER_SMTP_HOST=smtp.example.com
# PLANNER_SMTP_PORT=465
# PLANNER_SMTP_USER=bot@example.com
# PLANNER_SMTP_PASS=app-password
# PLANNER_SMTP_FROM=bot@example.com
